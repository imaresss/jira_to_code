#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/codex.sh"
source "$SCRIPT_DIR/cursor.sh"

usage() {
    cat << EOF
Usage: jira_to_code [OPTIONS]

Bridges Jira ticket management, Git version control, and AI-assisted coding (Codex or Cursor).

Options:
  -j ID       Jira ticket ID (e.g., PROJ-123)
  -p PATH     Project directory path (default: current directory)
  -b NAME     Base branch name (default: current branch)
  -a TOOL     AI tool: codex or cursor (default: codex)
  -i yes|no   Interactive session (default: yes). Use 'no' for non-interactive (codex exec, agent -p)
  -h          Show this help message

If any option is omitted, defaults are read from ~/.jira_to_code.rc (if present), then you are prompted.

Examples:
  jira_to_code -j RS-126 -p /path/to/repo -b main -a codex
  jira_to_code -j RS-126
  jira_to_code
EOF
    exit 0
}

# Pre-parse --help (getopts doesn't support long options)
for arg in "$@"; do
    case "$arg" in
        --help|-h) usage ;;
    esac
done

# Parse short options with getopts
while getopts "j:p:b:a:i:h" opt; do
    case $opt in
        j) JIRA_ID="$OPTARG" ;;
        p) PROJECT_PATH="$OPTARG" ;;
        b) MASTER_BRANCH="$OPTARG" ;;
        a) AI_TOOL_CHOICE="$OPTARG" ;;
        i) INTERACTIVE="$OPTARG" ;;
        h) usage ;;
        \?) usage ;;
    esac
done

# Load defaults from ~/.jira_to_code.rc (only for values not set via CLI)
load_rc_file() {
    local rc="$HOME/.jira_to_code.rc"
    [ -f "$rc" ] && [ -r "$rc" ] || return 0

    while IFS= read -r line || [ -n "$line" ]; do
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ "$line" =~ ^[[:space:]]*$ ]] && continue
        [[ "$line" =~ ^[[:space:]]*([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]] || continue

        local key="${BASH_REMATCH[1]}"
        local val="${BASH_REMATCH[2]}"
        val=$(echo "$val" | xargs)

        case "$key" in
            JIRA_ID)          [ -z "$JIRA_ID" ]          && JIRA_ID="$val" ;;
            PROJECT_PATH)     [ -z "$PROJECT_PATH" ]     && PROJECT_PATH="$val" ;;
            MASTER_BRANCH)    [ -z "$MASTER_BRANCH" ]    && MASTER_BRANCH="$val" ;;
            AI_TOOL)          [ -z "$AI_TOOL_CHOICE" ]   && AI_TOOL_CHOICE="$val" ;;
            INTERACTIVE)      [ -z "$INTERACTIVE" ]      && INTERACTIVE="$val" ;;
            USE_DEFAULT_MODEL) [ -z "$USE_DEFAULT_MODEL" ] && USE_DEFAULT_MODEL="$val" ;;
        esac
    done < "$rc"
}
load_rc_file

main() {
    echo "🚀 Welcome to jira_to_code!"
    echo "----------------------------"

    # 1. Prompt for Jira ID (Required) - only if not provided via getopts
    if [ -z "$JIRA_ID" ]; then
        read -p "Enter Jira ID or full link (e.g., PROJ-123 or https://genbanext.atlassian.net/browse/RS-126): " JIRA_ID
        JIRA_ID=$(echo "$JIRA_ID" | xargs)
    fi
    if [ -z "$JIRA_ID" ]; then
        echo "❌ Error: Jira ID cannot be empty."
        return 1
    fi
    # Extract Jira ID from full link if user pasted complete URL
    if [[ "$JIRA_ID" =~ /browse/([A-Za-z0-9]+-[0-9]+) ]]; then
        JIRA_ID="${BASH_REMATCH[1]}"
        echo "📍 Extracted Jira ID: $JIRA_ID"
    fi

    # 2. Prompt for Project Path (Defaults to current directory) - only if not provided via getopts
    if [ -z "$PROJECT_PATH" ]; then
        read -p "Enter Project Path [Press Enter for current dir]: " PROJECT_PATH
    fi
    PROJECT_PATH=${PROJECT_PATH:-$PWD}

    # 3. Prompt for Base Branch (Defaults to current branch) - only if not provided via getopts
    if [ -z "$MASTER_BRANCH" ]; then
        read -p "Enter Base Branch [Press Enter for current branch]: " MASTER_BRANCH
    fi

    # 4. Prompt for AI Tool Selection - only if not provided via getopts
    if [ -z "$AI_TOOL_CHOICE" ]; then
        echo ""
        echo "Which AI tool would you like to use?"
        echo "  codex) Codex"
        echo "  cursor) Cursor"
        read -p "Select tool (codex or cursor) [Press Enter for codex]: " AI_TOOL_CHOICE
    fi
    AI_TOOL_CHOICE=${AI_TOOL_CHOICE:-codex}
    AI_TOOL_CHOICE=$(echo "$AI_TOOL_CHOICE" | tr '[:upper:]' '[:lower:]')
    if [ "$AI_TOOL_CHOICE" != "codex" ] && [ "$AI_TOOL_CHOICE" != "cursor" ]; then
        echo "❌ Error: Invalid AI tool. Use 'codex' or 'cursor'."
        return 1
    fi

    # 4b. Prompt for Interactive session - only if not provided via getopts
    if [ -z "$INTERACTIVE" ]; then
        read -p "Interactive session? (yes/no) [Press Enter for yes]: " INTERACTIVE
    fi
    INTERACTIVE=${INTERACTIVE:-yes}
    INTERACTIVE=$(echo "$INTERACTIVE" | tr '[:upper:]' '[:lower:]')
    if [ "$INTERACTIVE" != "yes" ] && [ "$INTERACTIVE" != "no" ]; then
        echo "⚠️  Invalid value for interactive. Using 'yes'."
        INTERACTIVE="yes"
    fi

    echo "----------------------------"

    # 5. Navigate to the project path
    echo "📂 Navigating to $PROJECT_PATH..."
    cd "$PROJECT_PATH" || {
        echo "❌ Error: Directory '$PROJECT_PATH' does not exist or is not accessible."
        return 1
    }

    # Default to current branch if none provided
    if [ -z "$MASTER_BRANCH" ]; then
        MASTER_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
        if [ -z "$MASTER_BRANCH" ]; then
            echo "❌ Error: Not a git repository or unable to determine current branch."
            return 1
        fi
        echo "📍 Using current branch: $MASTER_BRANCH"
    fi

    # 6. Checkout the master/base branch
    echo "🌿 Checking out base branch: $MASTER_BRANCH..."
    git checkout "$MASTER_BRANCH" || {
        echo "❌ Error: Failed to checkout branch '$MASTER_BRANCH'. Make sure your working tree is clean."
        return 1
    }

    # 7. Fetch Jira ticket
    echo "🔍 Fetching Jira ticket $JIRA_ID..."
    local JIRA_CONTENT
    JIRA_CONTENT=$(jira issue view "$JIRA_ID" 2>/dev/null) || {
        echo "❌ Error: Failed to fetch Jira ticket '$JIRA_ID'. Check your Jira CLI authentication."
        return 1
    }

    # 8. Create or switch to the new feature branch
    echo "🔀 Switching to feature branch: feature/$JIRA_ID..."
    git checkout -b "feature/$JIRA_ID" 2>/dev/null || git checkout "feature/$JIRA_ID" || {
        echo "❌ Error: Failed to create or switch to feature branch 'feature/$JIRA_ID'."
        return 1
    }

    # 9. Build AI prompt (with optional user additions)
    local AI_PROMPT="Analyze the following Jira ticket and the current codebase. First, output a step-by-step implementation plan detailing which files need to be modified. Once you have output the plan, ask me to confirm if I want to proceed or make modifications. Then implement the code modifications. Ticket Details: $JIRA_CONTENT"

    EXTRA_PROMPT=""
    if [ "$INTERACTIVE" = "yes" ]; then
        read -p "Add additional prompt text (optional, press Enter to skip): " EXTRA_PROMPT
    fi
    if [ -n "$EXTRA_PROMPT" ]; then
        AI_PROMPT="${AI_PROMPT}"$'\n\n'"Additional user instructions: ${EXTRA_PROMPT}"
    fi

    # 10. Execute with selected AI Tool

    if [ "$AI_TOOL_CHOICE" = "codex" ]; then
        run_codex "$AI_PROMPT" "$INTERACTIVE" "$USE_DEFAULT_MODEL" || return 1
    elif [ "$AI_TOOL_CHOICE" = "cursor" ]; then
        run_cursor "$AI_PROMPT" "$INTERACTIVE" "$USE_DEFAULT_MODEL" || return 1
    else
        echo "❌ Error: Invalid AI tool selection."
        return 1
    fi

    echo "✅ Success! Ticket $JIRA_ID setup completed on branch feature/$JIRA_ID."
}

# Execute the main function
main
